# Environment Variables Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# Master Admin Credentials (for initial licensing setup)
# Generate secure passwords using: python -c "import secrets; print(secrets.token_urlsafe(32))"
MASTER_ADMIN_USER=your_master_username_here
MASTER_ADMIN_PASS=your_secure_password_here
MASTER_ADMIN_EMAIL=your_admin_email@example.com

# Optional: Database encryption key (for future use)
# DB_ENCRYPTION_KEY=your_32_char_encryption_key_here

# Optional: Google Drive API credentials (for cloud backup)
# GOOGLE_DRIVE_CLIENT_ID=your_client_id
# GOOGLE_DRIVE_CLIENT_SECRET=your_client_secret
# GOOGLE_DRIVE_TOKEN_FILE=path/to/token.json
