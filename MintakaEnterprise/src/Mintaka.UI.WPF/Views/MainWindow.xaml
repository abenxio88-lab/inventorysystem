<Window x:Class="Mintaka.UI.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Mintaka Enterprise Inventory System"
        Height="768" Width="1280"
        WindowState="Maximized"
        Background="#f3f4f6">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Navigation Bar -->
        <Border Grid.Row="0" Background="#1e3a8a" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and App Name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔷" FontSize="32" VerticalAlignment="Center"/>
                    <TextBlock Text="Mintaka Enterprise" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- User Info and Logout -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentUserName}" 
                               Foreground="#e5e7eb" 
                               FontSize="14" 
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                    <Button Content="Logout" 
                            Command="{Binding LogoutCommand}"
                            Padding="16,8"
                            Background="#dc2626"
                            FontSize="13"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <TabControl Grid.Row="1" Margin="16" Background="Transparent" BorderThickness="0">
            <TabItem Header="Dashboard" FontSize="14" Padding="16,8">
                <Border Background="White" CornerRadius="8" Padding="24" Margin="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Welcome to Mintaka Enterprise Inventory System" 
                                   FontSize="24" FontWeight="Bold" Foreground="#1f2937"
                                   Margin="0,0,0,24"/>

                        <!-- Dashboard KPI Cards -->
                        <UniformGrid Grid.Row="1" Rows="1" HorizontalAlignment="Stretch">
                            <!-- Total Products Card -->
                            <Border Background="#eff6ff" CornerRadius="8" Padding="24" Margin="8">
                                <StackPanel>
                                    <TextBlock Text="Total Products" FontSize="14" Foreground="#6b7280"/>
                                    <TextBlock Text="{Binding TotalProducts}" FontSize="36" FontWeight="Bold" Foreground="#2563eb" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Low Stock Card -->
                            <Border Background="#fef2f2" CornerRadius="8" Padding="24" Margin="8">
                                <StackPanel>
                                    <TextBlock Text="Low Stock Items" FontSize="14" Foreground="#6b7280"/>
                                    <TextBlock Text="{Binding LowStockCount}" FontSize="36" FontWeight="Bold" Foreground="#dc2626" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Expiring Soon Card -->
                            <Border Background="#fffbeb" CornerRadius="8" Padding="24" Margin="8">
                                <StackPanel>
                                    <TextBlock Text="Expiring Soon" FontSize="14" Foreground="#6b7280"/>
                                    <TextBlock Text="{Binding ExpiringSoonCount}" FontSize="36" FontWeight="Bold" Foreground="#f59e0b" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Total Value Card -->
                            <Border Background="#ecfdf5" CornerRadius="8" Padding="24" Margin="8">
                                <StackPanel>
                                    <TextBlock Text="Inventory Value" FontSize="14" Foreground="#6b7280"/>
                                    <TextBlock Text="{Binding TotalInventoryValue, StringFormat={}{0:C}}" FontSize="36" FontWeight="Bold" Foreground="#059669" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Grid>
                </Border>
            </TabItem>

            <TabItem Header="Products" FontSize="14" Padding="16,8">
                <Border Background="White" CornerRadius="8" Padding="24" Margin="8">
                    <TextBlock Text="Product Management - Coming Soon" FontSize="18" Foreground="#6b7280"/>
                </Border>
            </TabItem>

            <TabItem Header="Sales" FontSize="14" Padding="16,8">
                <Border Background="White" CornerRadius="8" Padding="24" Margin="8">
                    <TextBlock Text="Sales Orders - Coming Soon" FontSize="18" Foreground="#6b7280"/>
                </Border>
            </TabItem>

            <TabItem Header="Purchases" FontSize="14" Padding="16,8">
                <Border Background="White" CornerRadius="8" Padding="24" Margin="8">
                    <TextBlock Text="Purchase Orders - Coming Soon" FontSize="18" Foreground="#6b7280"/>
                </Border>
            </TabItem>

            <TabItem Header="Reports" FontSize="14" Padding="16,8">
                <Border Background="White" CornerRadius="8" Padding="24" Margin="8">
                    <TextBlock Text="Analytics & Reports - Coming Soon" FontSize="18" Foreground="#6b7280"/>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
