*.obj
*.lib
*.exe
*.dll
*.zip
*.7z
*.rar
*.tar.gz
*.iso
*.msi

# Documentation builds
docs/_build/

# Jupyter
.ipynb_checkpoints

# mypy
.dmypy.json
dmypy.json

