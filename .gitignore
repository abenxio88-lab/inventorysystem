venv/
ENV/
env/
.venv

# PyInstaller
*.manifest
*.spec

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Type checking
.mypy_cache/

# Linting
.ruff_cache/

# Logs
*.log
logs/

# Database
*.db
*.db-journal
*.sqlite
*.sqlite3

# Data directory
data/
!data/.gitkeep

# Backup files
backups/
*.bak
*.backup

# OS
.DS_Store
Thumbs.db
desktop.ini

# Configuration (keep sample, ignore actual)
config.yaml
!config.yaml.example

# Secrets
.env
.env.local
*.key
*.pem
*.crt

# Temporary files
tmp/
temp/
*.tmp
*.temp

